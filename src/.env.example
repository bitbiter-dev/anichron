# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# PostgreSQL password for anichron_admin
DB_PW=change_me

# Base path on the host for persistent data volumes
# Example: BASE_PATH=/mnt/data  →  mounts /mnt/data/anichron/proxy_cache
BASE_PATH=/your/base/path
